generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  username           String?           @unique
  name               String?
  password           String
  role               Role              @default(USER)
  active             Boolean           @default(true)
  mustChangePassword Boolean           @default(false)
  protected          Boolean           @default(false)
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  tasks              Task[]
  tags               Tag[]
  createdGroups      Group[]           @relation("GroupCreator")
  memberships        GroupMembership[]
  joinRequests       JoinRequest[]
  incidents          Incident[]
  notifications      Notification[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      Status    @default(TODO)
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subtasks    Subtask[]
  tags        Tag[]     @relation("TaskTags")

  @@index([userId])
  @@index([groupId])
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Tag {
  id     String @id @default(cuid())
  name   String
  color  String @default("#6366f1")
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[] @relation("TaskTags")

  @@unique([name, userId])
  @@index([userId])
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Role {
  USER
  ADMIN
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String
}

model Group {
  id           String            @id @default(cuid())
  name         String
  description  String?
  isPersonal   Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdBy    String
  creator      User              @relation("GroupCreator", fields: [createdBy], references: [id])
  memberships  GroupMembership[]
  tasks        Task[]
  joinRequests JoinRequest[]

  @@index([createdBy, isPersonal])
}

model GroupMembership {
  id          String   @id @default(cuid())
  userId      String
  groupId     String
  permissions Int      @default(23)
  joinedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

model JoinRequest {
  id        String            @id @default(cuid())
  userId    String
  groupId   String
  status    JoinRequestStatus @default(PENDING)
  message   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Incident Management Models

model Incident {
  id            String          @id @default(cuid())
  title         String
  description   String?
  severity      Severity        @default(MEDIUM)
  status        IncidentStatus  @default(OPEN)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  resolvedAt    DateTime?
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeline      TimelineEvent[]
  notifications Notification[]

  @@index([userId])
  @@index([status])
}

model TimelineEvent {
  id         String    @id @default(cuid())
  incidentId String
  incident   Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       EventType
  message    String
  createdAt  DateTime  @default(now())

  @@index([incidentId])
}

model Notification {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([incidentId])
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

enum EventType {
  CREATED
  STATUS_CHANGED
  SEVERITY_CHANGED
  NOTE_ADDED
  RESOLVED
}
